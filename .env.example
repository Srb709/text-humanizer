# ─── Claude API ────────────────────────────────────────────────────────────────
# Get at: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Get at: dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── App URL ───────────────────────────────────────────────────────────────────
# No trailing slash. Use http://localhost:3000 for local dev.
NEXT_PUBLIC_URL=https://your-domain.vercel.app

# ─── AutoPilot: WordPress ──────────────────────────────────────────────────────
# Your blog URL (no trailing slash)
WORDPRESS_URL=https://yourblog.com
# Your WordPress admin username
WORDPRESS_USERNAME=admin
# Generate at: WP Admin → Users → Your Profile → Application Passwords
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ─── AutoPilot: Twitter / X ────────────────────────────────────────────────────
# Requires Basic tier ($100/mo) for write access
# Get at: developer.twitter.com → Project → App → Keys and Tokens
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ─── AutoPilot: Reddit ─────────────────────────────────────────────────────────
# Create a "script" app at: reddit.com/prefs/apps (free)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
# Comma-separated, with or without "r/" prefix
REDDIT_SUBREDDITS=r/entrepreneur,r/marketing,r/startups

# ─── AutoPilot: Content Settings ───────────────────────────────────────────────
# Comma-separated keywords — one is used per day, rotating
AUTOPILOT_KEYWORDS=AI copywriting tool,email subject line generator,ad copy generator,marketing copy AI,AI writing assistant,product description generator,blog outline generator

# Your brand name (appears in generated content)
AUTOPILOT_SITE_NAME=CopyFlow AI

# Your site URL (linked in blog CTAs)
AUTOPILOT_SITE_URL=https://your-domain.vercel.app

# ─── Vercel Cron Auth ──────────────────────────────────────────────────────────
# Vercel sets this automatically — no action needed
# CRON_SECRET=auto-set-by-vercel
